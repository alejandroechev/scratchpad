{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ScratchPad",
  "version": "0.13.0",
  "identifier": "app.stormlab.scratchpad",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ScratchPad",
        "width": 420,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "additionalBrowserArgs": "--remote-debugging-port=9222",
        "backgroundColor": [217, 119, 6, 255]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
