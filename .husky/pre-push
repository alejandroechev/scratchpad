#!/bin/sh

echo "🔍 Pre-push: Running full validation gate..."

npx tsc -b || exit 1
npx vitest run --coverage || exit 1
npx eslint src/ --max-warnings 0 || exit 1

echo "🎭 Pre-push: E2E tests..."
npx playwright test || exit 1

if [ -f "src-tauri/tauri.conf.json" ]; then
  echo "🔢 Pre-push: Checking version bump..."
  LOCAL_VERSION=$(node -p "require('./package.json').version" 2>/dev/null)
  REMOTE_VERSION=$(git show origin/master:package.json 2>/dev/null | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d).version))" 2>/dev/null)
  if [ -n "$LOCAL_VERSION" ] && [ -n "$REMOTE_VERSION" ] && [ "$LOCAL_VERSION" = "$REMOTE_VERSION" ]; then
    echo "❌ Version not bumped! Local and remote are both v${LOCAL_VERSION}."
    echo "   Bump version in package.json AND src-tauri/tauri.conf.json before pushing."
    exit 1
  fi
  echo "   v${REMOTE_VERSION:-new} → v${LOCAL_VERSION} ✓"
fi

if [ -f "src-tauri/tauri.conf.json" ]; then
  echo "🖥️ Pre-push: CDP visual validation on Tauri desktop app..."
  npx tsx scripts/cdp-visual-validate.ts || {
    echo "⚠️  CDP validation failed — check screenshots/ for details."
    exit 1
  }
fi

echo "✅ Pre-push: All checks passed! Safe to push."
echo ""
echo "⚠️  REMINDER: Monitor the CI/CD pipeline after push completes!"
echo "   Run: npx tsx scripts/monitor-pipeline.ts"