{
  "name": "scratchpad",
  "private": true,
  "version": "0.11.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "cli": "npx tsx src/cli/index.ts",
    "tauri": "tauri",
    "test:cdp": "npx tsx scripts/cdp-visual-validate.ts",
    "test:all": "npm run test && npm run test:e2e && npm run test:cdp",
    "pipeline:monitor": "npx tsx scripts/monitor-pipeline.ts",
    "prepare": "husky",
    "verdant:generate": "node ./node_modules/@verdant-web/cli/dist/bin/index.js -s src/infra/verdant/schema.ts -o src/infra/verdant/client -r --select=publish"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.5",
    "@automerge/automerge-repo": "^2.5.4",
    "@automerge/automerge-repo-network-websocket": "^2.5.4",
    "@automerge/automerge-repo-react-hooks": "^2.5.4",
    "@automerge/automerge-repo-storage-indexeddb": "^2.5.4",
    "@heroicons/react": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@verdant-web/react": "^43.1.0",
    "@verdant-web/store": "^5.4.0",
    "commander": "^14.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tauri-plugin-mobile-sharetarget-api": "^2.0.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@verdant-web/cli": "^5.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
