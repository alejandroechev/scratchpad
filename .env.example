# SyncEngine WebSocket URL
VITE_SYNC_SERVER_URL=wss://sync.stormlab.app

# Automerge document URL (shared across all devices)
# Leave empty on first launch — the app creates a new doc automatically.
# After first launch, copy the Doc URL from the ⓘ info panel and set it here
# so all devices share the same document.
VITE_AUTOMERGE_DOC_URL=
